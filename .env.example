# Development environment example
PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/blood-donation
NODE_ENV=development
JWT_SECRET=replace-with-a-long-random-development-secret
JWT_EXPIRES_IN=7d
CLIENT_ORIGIN=http://localhost:5500

# Admin management scripts read these values from the environment.
ADMIN_EMAIL=<admin-email>
ADMIN_PASSWORD=<admin-password>

# Production safety guards
ALLOW_ADMIN_CREATE=false
ADMIN_RESET_CONFIRM=no

# Development note:
# The backend may allow the browser's null origin only in development for local file:// testing.
# Do not enable null-origin access in production.
