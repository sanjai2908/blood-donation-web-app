PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/blood-donation

# Admin management scripts read these values when creating or resetting the admin user.
ADMIN_EMAIL=<admin-email>
ADMIN_PASSWORD=<admin-password>

# Generate a long random secret for production and keep it private.
JWT_SECRET=replace-with-a-strong-random-production-secret
JWT_EXPIRES_IN=7d

# Comma-separated origins allowed to call the API from the browser.
CLIENT_ORIGIN=https://your-domain.example,https://www.your-domain.example

NODE_ENV=production

# Safety guard for admin creation/reset scripts in production.
ALLOW_ADMIN_CREATE=false
ADMIN_RESET_CONFIRM=no